# TrenchSniper OS Environment
# Copy this to .env.local and fill in your values

# Solana RPC (devnet for testing)
SOLANA_RPC_URL=https://api.devnet.solana.com

# For mainnet:
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Wallet Mnemonic (12 or 24 words) - KEEP SECRET
# This generates ALL sniper wallets. Store safely!
# WALLET_MNEMONIC=apple banana cherry ... (12 words)

# Number of sniper wallets to generate from mnemonic
WALLET_COUNT=5

# Telegram Bot (optional) 
# Get from @BotFather - send /newbot in Telegram
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Allium API (for on-chain detection queries)
# Get your key at https://app.allium.so
# ALLIUM_API_KEY=your-allium-api-key-here

# Jito MEV (optional - for bundles)
# Get from jito-labs GitHub or waitlist
# JITO_AUTH_KEY=your_key_here

# Strategy: aggressive | balanced | conservative
STRATEGY=balanced
